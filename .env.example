# Copie para .env e ajuste os valores antes de subir os containers.
# .env nunca deve ser versionado (já está no .gitignore).

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=mtg_collection
MYSQL_USER=mtg
MYSQL_PASSWORD=change_me_password

# Portas no host. Mude se já tiver algo rodando nessas portas.
# (DB_PORT não é mais publicado — o MySQL fica só na rede interna; a
# variável continua aqui só para o detector de conflito do setup.sh.)
DB_PORT=3306
API_PORT=3001
UI_PORT=5173

# Prefixo dos nomes de container (mtg_db, mtg_api, mtg_ui por padrão).
# Mude para rodar uma segunda instância do projeto na mesma máquina
# sem colidir nomes (ex: CONTAINER_PREFIX=mtg2 -> mtg2_db, mtg2_api...).
CONTAINER_PREFIX=mtg

# Segredo usado para assinar tokens JWT (autenticação multi-usuário).
# setup.sh gera um valor aleatório automaticamente na primeira execução.
# Sem isso definido, a API usa um segredo aleatório por processo — sessões
# não sobrevivem a um restart. Defina algo fixo para produção real.
JWT_SECRET=change_me_jwt_secret

# Defina como "production" ao expor na internet (ex: Cloudflare Tunnel):
# faz o error handler esconder detalhes de SQL do cliente. Deixe vazio
# localmente para ver os erros completos durante o desenvolvimento.
NODE_ENV=

