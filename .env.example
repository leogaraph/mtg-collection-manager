# Copie para .env e ajuste os valores antes de subir os containers.
# .env nunca deve ser versionado (já está no .gitignore).

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=mtg_collection
MYSQL_USER=mtg
MYSQL_PASSWORD=change_me_password

# Portas no host. Mude se já tiver algo rodando nessas portas
# (ex: outro projeto Docker usando 3306/3001/5173).
DB_PORT=3306
API_PORT=3001
UI_PORT=5173

# Prefixo dos nomes de container (mtg_db, mtg_api, mtg_ui por padrão).
# Mude para rodar uma segunda instância do projeto na mesma máquina
# sem colidir nomes (ex: CONTAINER_PREFIX=mtg2 -> mtg2_db, mtg2_api...).
CONTAINER_PREFIX=mtg

